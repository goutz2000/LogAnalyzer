<Window x:Class="LogAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LogAnalyzer - Bitstream Log File Translator" Height="800" Width="1200"
        Background="#F5F5F5" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Background="#2C3E50" Padding="20">
            <TextBlock Text="LogAnalyzer" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="BrowseButton" Click="BrowseButton_Click" Background="#3498DB" Foreground="White" Padding="12,8" FontSize="14" FontWeight="Bold" Cursor="Hand">📂 Open Log File</Button>
                <TextBlock x:Name="FilePathLabel" Foreground="#ECF0F1" VerticalAlignment="Center" Margin="10,0" FontSize="12"/>
            </StackPanel>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Entries List -->
            <StackPanel Grid.Column="0" Background="White" Margin="0,0,10,0">
                <TextBlock Text="Log Entries" FontSize="14" FontWeight="Bold" Background="#ECF0F1" Padding="10" Margin="0,0,0,10"/>
                
                <!-- Filter Buttons -->
                <StackPanel Orientation="Horizontal" Padding="10" Spacing="5" Margin="0,0,0,10">
                    <Button x:Name="FilterAllButton" Click="FilterButton_Click" Tag="All" Background="#3498DB" Foreground="White" Padding="8,4" FontSize="11" Cursor="Hand">All</Button>
                    <Button x:Name="FilterInfoButton" Click="FilterButton_Click" Tag="info" Background="#27AE60" Foreground="White" Padding="8,4" FontSize="11" Cursor="Hand">Info</Button>
                    <Button x:Name="FilterWarningButton" Click="FilterButton_Click" Tag="warning" Background="#F39C12" Foreground="White" Padding="8,4" FontSize="11" Cursor="Hand">Warning</Button>
                    <Button x:Name="FilterErrorButton" Click="FilterButton_Click" Tag="error" Background="#E74C3C" Foreground="White" Padding="8,4" FontSize="11" Cursor="Hand">Error</Button>
                </StackPanel>

                <!-- Entries ListBox -->
                <ListBox x:Name="EntriesListBox" SelectionChanged="EntriesListBox_SelectionChanged" Margin="10" Background="#FAFAFA" ScrollViewer.VerticalScrollBarVisibility="Auto" Height="700">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5">
                                <TextBlock Text="{Binding TimeDisplay}" FontSize="11" Foreground="#7F8C8D" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TypeDisplay}" FontSize="10" Foreground="#95A5A6"/>
                                <TextBlock Text="{Binding Preview}" FontSize="10" Foreground="#2C3E50" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <!-- Divider -->
            <GridSplitter Grid.Column="1" Width="5" Background="#BDC3C7" HorizontalAlignment="Stretch"/>

            <!-- Right Panel: Details -->
            <StackPanel Grid.Column="2" Background="White" Margin="10,0,0,0" x:Name="DetailsPanel" Visibility="Hidden">
                <TextBlock Text="Entry Details" FontSize="14" FontWeight="Bold" Background="#ECF0F1" Padding="10" Margin="0,0,0,10"/>
                <ScrollViewer Margin="10" VerticalScrollBarVisibility="Auto" Height="700">
                    <StackPanel>
                        <!-- Timestamp -->
                        <TextBlock Text="Timestamp" FontSize="12" FontWeight="Bold" Foreground="#2C3E50" Margin="0,10,0,5"/>
                        <TextBlock x:Name="TimestampLabel" FontSize="11" Foreground="#34495E" Margin="0,0,0,10" TextWrapping="Wrap"/>

                        <!-- Type -->
                        <TextBlock Text="Log Type" FontSize="12" FontWeight="Bold" Foreground="#2C3E50" Margin="0,10,0,5"/>
                        <TextBlock x:Name="TypeLabel" FontSize="11" Foreground="#34495E" Margin="0,0,0,10"/>

                        <!-- Raw Text -->
                        <TextBlock Text="Raw Text" FontSize="12" FontWeight="Bold" Foreground="#2C3E50" Margin="0,10,0,5"/>
                        <TextBlock x:Name="RawTextLabel" FontSize="10" Foreground="#34495E" Margin="0,0,0,10" TextWrapping="Wrap" FontFamily="Courier New"/>

                        <!-- Bitstream Data -->
                        <TextBlock Text="Bitstream Analysis" FontSize="12" FontWeight="Bold" Foreground="#2C3E50" Margin="0,10,0,5"/>
                        <ItemsControl x:Name="BitstreamItemsControl" Margin="0,0,0,10">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,5,0,0">
                                        <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3" TextBlock.Foreground="#7F8C8D" TextBlock.FontSize="10">
                                            <TextBlock Text="Binary: " FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Binary}" FontFamily="Courier New"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3" TextBlock.Foreground="#7F8C8D" TextBlock.FontSize="10">
                                            <TextBlock Text="Decimal: " FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Decimal}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8" TextBlock.Foreground="#7F8C8D" TextBlock.FontSize="10">
                                            <TextBlock Text="Hex: " FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Hex}"/>
                                        </StackPanel>
                                        <!-- Visual Indicators -->
                                        <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,0,0,10">
                                            <ItemsControl ItemsSource="{Binding Bits}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="2"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Ellipse Width="16" Height="16" Fill="{Binding Color}" Stroke="#BDC3C7" StrokeThickness="1" ToolTip="{Binding Value}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        <Border BorderThickness="0,1,0,0" BorderBrush="#ECF0F1" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="#34495E" Foreground="White" Padding="10">
            <TextBlock x:Name="StatusLabel" Text="Ready" FontSize="11"/>
            <Separator Background="#7F8C8D" Margin="10,0"/>
            <TextBlock x:Name="CountLabel" Text="Entries: 0" FontSize="11"/>
        </StatusBar>
    </Grid>
</Window>